# swim-coach backend (backend/app) -- environment configuration.
#
# Copy to `.env` in the repo root (or in backend/, either works since
# python-dotenv's load_dotenv() searches upward from the cwd) and fill in
# real values for local dev -- it's auto-loaded on startup. Never commit
# `.env` -- it's gitignored.
# Cloud Run reads these as real environment variables / Secret Manager
# references instead (see .github/workflows/deploy-backend.yml); no .env
# file exists in the deployed image.

# --- required, fail-fast if missing ---------------------------------------

# Your Anthropic API key (console.anthropic.com). Required -- the app
# refuses to start without it.
ANTHROPIC_API_KEY=

# The bearer token clients must send as `Authorization: Bearer <token>`.
# Compared via constant-time sha256-hash comparison server-side (auth.py) --
# choose a long random value, e.g. `openssl rand -hex 32`. Required --
# the app refuses to start without it. Auth-lite v1: one shared token for a
# single-athlete deployment; swapped for Supabase JWT auth in Phase 3.
API_TOKEN=

# The OAuth client id Google ID tokens must carry as `aud` (verified
# server-side by POST /api/auth/google -- see backend/app/routes/auth.py and
# app/google_auth.py). NOT a secret -- it's the SAME public client id the
# frontend already bakes into its build as VITE_GOOGLE_CLIENT_ID (see
# web/src/identity.js and .github/workflows/deploy.yml) -- but still
# required at startup: without it, there's no audience to check a token
# against, which would silently accept a token minted for a different OAuth
# client. Required -- the app refuses to start without it.
GOOGLE_CLIENT_ID=

# --- optional, sensible defaults shown -------------------------------------

# Claude model id.
CLAUDE_MODEL=claude-opus-4-8

# "adaptive" sends thinking:{"type":"adaptive"} (let the model decide how
# much to reason per turn). "disabled" sends thinking:{"type":"disabled"}
# for lower latency/cost. Both are passed explicitly (omitting the param
# would mean adaptive on Sonnet 5 but OFF on Opus 4.8). No other values.
CLAUDE_THINKING=adaptive

# Comma-separated list of allowed CORS origins for the PWA.
ALLOWED_ORIGINS=https://ashaber.github.io

# Athlete data tree and research library, relative to backend/ (where
# uvicorn is run from) by default -- override with absolute paths in Docker
# (see backend/Dockerfile, which lays out /app/athletes, /app/library
# alongside /app/backend so these defaults resolve unchanged).
ATHLETES_DIR=../athletes
LIBRARY_DIR=../library
# (research/open-questions.jsonl -- IDEA 005 -- is derived from
# ATHLETES_DIR's parent directory, not a separate env var.)

# HTTP port uvicorn binds to.
PORT=8000

# Per-token rate limit on POST /api/chat, requests per rolling 60s window.
CHAT_RATE_PER_MIN=20

# --- verified identity (Slice 1, backend/app/routes/auth.py) ---------------

# How long a session token minted by POST /api/auth/google stays valid
# before the athlete has to sign in again.
SESSION_TTL_DAYS=30

# Daily cap on POST /api/chat, per ATHLETE SESSION (never applied to the
# legacy shared API_TOKEN service credential -- see app/auth.py's
# require_daily_chat_cap). Exists because the Anthropic key is Andrew's
# own; once other people can chat, they spend his credits.
CHAT_DAILY_CAP_PER_ATHLETE=50

# --- storage backend (Phase 2.5) ------------------------------------------

# Which persistence backend the store factory (app/store_factory.py) builds.
#   file  -> FileStore over ATHLETES_DIR (the YAML tree). DEFAULT.
#   db    -> DbStore over Supabase/Postgres (DATABASE_URL, below).
# Leave as `file` (or unset) to keep the live backend UNCHANGED. Flip to `db`
# only after provisioning Supabase, running the migration, and shadow-verifying
# (see README "Store backend cutover"). Rollback = set back to `file`.
STORE_BACKEND=file

# Supabase connection string, REQUIRED when STORE_BACKEND=db (fail-fast if
# missing). Use the TRANSACTION POOLER (pgbouncer, port 6543) for app traffic --
# DbStore disables prepared statements (prepare_threshold=None) to work with it.
# Use the direct connection (port 5432) only for migrations/DDL.
# postgresql://postgres.<project-ref>:<pw>@<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=

# --- intervals.icu auto-sync job (Phase 3, backend/app/sync.py) ------------

# Only read by `python -m app.sync` (the Cloud Run Job, not the API service).
# REQUIRED for that job -- fails fast if missing/malformed. JSON array, one
# entry per synced athlete: `slug` matches the athlete's directory under
# ATHLETES_DIR; `intervals_athlete_id` and `api_key` come from that athlete's
# own intervals.icu account (Settings -> Developer -- each athlete generates
# and supplies their own key, it is never shared). See backend/README.md's
# "intervals.icu sync job" setup section for how this gets into Secret
# Manager -- never commit real values here.
# INTERVALS_SYNC_CONFIG=[{"slug":"andrew","intervals_athlete_id":"i00000001","api_key":"REPLACE_ME"},{"slug":"renee","intervals_athlete_id":"i00000002","api_key":"REPLACE_ME"}]
