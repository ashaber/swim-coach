# The backend image builds from the repo root (backend/Dockerfile COPYs
# engine/, library/, athletes/, scripts/). Docker reads the ignore file from
# the build-context root, so it lives here, not in backend/.
.git/
.venv/
**/__pycache__/
**/*.pyc
.pytest_cache/
**/.env
*.log
node_modules/
web/node_modules/
web/dist/
.vite/
web/public/data/*.json
.claude/worktrees/
tests/
dist/
